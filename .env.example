PORT=8001
AI_API_URL=http://host.docker.internal:8080/v1/
STORAGE_BACKEND=sqlite
SQLITE_DB_PATH=./data/healthy-diet-agent.db
CLI_USER_ID=local-user
CLI_THREAD_ID=local-thread

# Optional when STORAGE_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Google chat routing
# Current repo code reads GEMINI_AI_API first; GEMINI_API_KEY is only a fallback in src/server/modelRouting.ts.
GEMINI_AI_API=your-google-api-key
GOOGLE_CHAT_MODEL=gemma-4-31b-it
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Repo-level role, prompt, MOHW, and RAG defaults live in agent_config.json.
# Use env values here only for deployment-specific overrides.
MOHW_NEWS_SYNC_ENABLED=true
MOHW_NEWS_SYNC_INTERVAL_MINUTES=360
MOHW_NEWS_SYNC_RUN_ON_START=true

RAG_DOCS_ROOT=/app/uploads

RAG_WORKER_ENABLED=true
RAG_WORKER_POLL_SECONDS=5
RAG_WORKER_BATCH_SIZE=3
RAG_WORKER_MAX_RETRIES=3
RAG_WORKER_RETRY_BASE_SECONDS=30
RAG_WORKER_MAX_BACKOFF_SECONDS=1800
RAG_WORKER_PROCESSING_TIMEOUT_SECONDS=900
RAG_WORKER_STUCK_BATCH_SIZE=20
